{
  "name": "starship-architect",
  "version": "1.0.0",
  "description": "Traveller Starship Architect Tool - Design and layout starship components",
  "scripts": {
    "build": "node build.js",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "serve": "python -m http.server 8000",
    "serve:dist": "cd dist && python -m http.server 8000",
    "lint": "eslint src/ build.js jest.config.js tests/jest-setup.js \"tests/unit/**/*.test.js\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "traveller",
    "starship",
    "architect",
    "ship-design"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "clean-css": "^5.3.3",
    "eslint": "^8.57.0",
    "html-minifier": "^4.0.0",
    "jest": "^29.7.0",
    "terser": "^5.26.0"
  }
}
